# Instalando pacotes ---------------------------------
install.packages("janitor")
install.packages("tidyverse")

# Ativando pacotes------------------------------------
library(tidyverse)
library(janitor)



# importando dados do github (csv)--------------------------------


url <- "https://raw.githubusercontent.com/drewmelo/cursoR/refs/heads/master/projetos/mercado_trabalho_pi.csv"
dados_projeto <- read_csv2(url) |> 
  clean_names()


# QUESTÃO 1: Qual é o nível de escolaridade mais frequente?
# Criando a tabela de contagem e porcentagem

tabela_frequencia <- dados_projeto |> 
  drop_na(nivel_instrucao) |>
  count(nivel_instrucao) |> 
  mutate(Porcentagem = (n / sum(n)) * 100)

#grafico 
  ggplot(tabela_frequencia, aes(nivel_instrucao, Porcentagem)) +
  geom_col(fill = "steelblue", color = "black")+
    labs(
      title = "Porcentagem do Nível de Instrução no Piauí",
      x = "Nível de Instrução",
      y = "Porcentagem (%)"
    ) +
    theme_minimal() +
    theme(axis.text.x = element_text(angle = 45, hjust = 1))

glimpse(tabela_frequencia)

