# QUESTÃO 4: renda média por nível de instrução e sexo


Tabela_geral <- dados_projeto |> 
  drop_na(nivel_instrucao, renda) |> 
  group_by(nivel_instrucao) |> 
  summarise(
    Renda_Media_Geral = mean(renda, na.rm = TRUE)
  )

# tabela com separacao de sexo
tabela_sexo <- dados_projeto |> 
  drop_na(nivel_instrucao, renda, sexo) |>
  group_by(nivel_instrucao, sexo) |> 
  summarise(
    renda_media = mean(renda, na.rm = TRUE)
  ) |> 
  pivot_wider(
    names_from = sexo,        
    values_from = renda_media
  )

tabela_final.s <- left_join(Tabela_geral, tabela_sexo, by = "nivel_instrucao")

