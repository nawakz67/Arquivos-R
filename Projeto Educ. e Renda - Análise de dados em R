# QUESTÃO 2: Como a renda média e mediana variam entre os níveis de instrução?
# Agrupando os dados para calcular média e mediana
tabela_renda <- dados_projeto |>
  drop_na(nivel_instrucao, renda) |> 
  group_by(nivel_instrucao) |> 
  summarise(
    renda_media = mean(renda, na.rm = T),
    renda_mediana = median(renda, na.rm = T),
    quantidade_trabalhadores = n()
  )

glimpse(tabela_renda)

#grafico
  ggplot(tabela_renda, aes(renda_media, nivel_instrucao)) +
  geom_col(fill = "steelblue", color = "black") +
  labs(
    title = "Renda Média por Nível de Instrução no Piauí",
    x = "Renda Média (R$)",
    y = "Nível de Instrução"
  ) +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))

print(tabela_renda)


# QUESTÃO 3: A renda tende a aumentar conforme crescem os anos de estudo?
# Calculando a média de renda para cada ano de estudo numérico

renda_anos <- dados_projeto |> 
  drop_na(anos_estudo_num, renda) |>
  group_by(anos_estudo_num) |> 
  summarise(renda_media = mean(renda, na.rm = TRUE))

# grafico 
  ggplot(renda_anos, aes(anos_estudo_num, renda_media)) +
  geom_point() +
  labs(
    title = "Evolução da Renda Média por Anos de Estudo",
    x = "Anos de Estudos",
    y = "Renda Média (R$)"
  ) +
  theme_minimal() +
  theme(axis.text.x = element_text(angle = 45, hjust = 1))


